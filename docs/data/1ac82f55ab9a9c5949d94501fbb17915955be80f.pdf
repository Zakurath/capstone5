                    </msub>
                  </mrow>
                  <msub>
                    <mi>h</mi>
                    <mrow>
                      <mi>i</mi>
                      <mo>+</mo>
                      <mn>1</mn>
                    </mrow>
                  </msub>
                </mfrac>
              </mstyle>
              <mo stretchy="false">)</mo>
            </mrow>
            <mo>+</mo>
            <msubsup>
              <mi>x</mi>
              <mrow>
                <mi>i</mi>
                <mo>+</mo>
                <mn>1</mn>
              </mrow>
              <mo>′</mo>
            </msubsup>
            <msub>
              <mi>ψ</mi>
              <mn>1</mn>
            </msub>
            <mrow>
              <mo stretchy="false">(</mo>
              <mstyle scriptlevel="0" displaystyle="true">
                <mfrac>
                  <mrow>
                    <mi>S</mi>
                    <mo>−</mo>
                    <msub>
                      <mi>S</mi>
                      <mi>i</mi>
                    </msub>
                  </mrow>
                  <msub>
                    <mi>h</mi>
                    <mrow>
                      <mi>i</mi>
                      <mo>+</mo>
                      <mn>1</mn>
                    </mrow>
                  </msub>
                </mfrac>
              </mstyle>
              <mo stretchy="false">)</mo>
            </mrow>
          </mfenced>
          <mo>,</mo>
        </mrow>
      </mtd>
    </mtr>
  </mtable>
</semantics></math>
      </div>
      <div class='l'>
      <label >(11)</label>
      </div>
    </div>
        where <math display='inline'><semantics>
  <mrow>
    <msub>
      <mi>h</mi>
      <mrow>
        <mi>i</mi>
        <mo>+</mo>
        <mn>1</mn>
      </mrow>
    </msub>
    <mo>=</mo>
    <msub>
      <mi>S</mi>
      <mrow>
        <mi>i</mi>
        <mo>+</mo>
        <mn>1</mn>
      </mrow>
    </msub>
    <mo>−</mo>
    <msub>
      <mi>S</mi>
      <mi>i</mi>
    </msub>
  </mrow>
</semantics></math>, <math display='inline'><semantics>
  <mrow>
    <msub>
      <mi>x</mi>
      <mi>i</mi>
    </msub>
    <mo>=</mo>
    <mi>x</mi>
    <mrow>
      <mo stretchy="false">(</mo>
      <msub>
        <mi>S</mi>
        <mi>i</mi>
      </msub>
      <mo stretchy="false">)</mo>
    </mrow>
  </mrow>
</semantics></math>, and <math display='inline'><semantics>
  <mrow>
    <msubsup>
      <mi>x</mi>
      <mi>i</mi>
      <mo>′</mo>
    </msubsup>
    <mo>=</mo>
    <msup>
      <mi>x</mi>
      <mo>′</mo>
    </msup>
    <mrow>
      <mo stretchy="false">(</mo>
      <msub>
        <mi>S</mi>
        <mi>i</mi>
      </msub>
      <mo stretchy="false">)</mo>
    </mrow>
  </mrow>
</semantics></math>. The Hermite basis functions are
        <div class='html-disp-formula-info' id='FD12-jimaging-11-00014'>
      <div class='f'>
        <math display='block'><semantics>
  <mtable displaystyle="true">
    <mtr>
      <mtd columnalign="right">
        <mrow/>
      </mtd>
      <mtd/>
      <mtd columnalign="left">
        <mrow>
          <mspace width="-42.67912pt"/>
          <msub>
            <mi>ϕ</mi>
