                <mo>+</mo>
                <msub>
                  <mi>h</mi>
                  <mrow>
                    <mi>i</mi>
                    <mo>+</mo>
                    <mn>1</mn>
                  </mrow>
                </msub>
              </mrow>
            </mfrac>
          </mstyle>
          <mo>,</mo>
          <mspace width="3.33333pt"/>
          <msub>
            <mi>μ</mi>
            <mi>i</mi>
          </msub>
          <mo>=</mo>
          <mstyle scriptlevel="0" displaystyle="true">
            <mfrac>
              <msub>
                <mi>h</mi>
                <mi>i</mi>
              </msub>
              <mrow>
                <msub>
                  <mi>h</mi>
                  <mi>i</mi>
                </msub>
                <mo>+</mo>
                <msub>
                  <mi>h</mi>
                  <mrow>
                    <mi>i</mi>
                    <mo>+</mo>
                    <mn>1</mn>
                  </mrow>
                </msub>
              </mrow>
            </mfrac>
          </mstyle>
          <mo>,</mo>
          <mspace width="3.33333pt"/>
          <msub>
            <mi>c</mi>
            <mi>i</mi>
          </msub>
          <mo>=</mo>
          <mstyle scriptlevel="0" displaystyle="true">
            <mfrac>
              <mn>3</mn>
              <mrow>
