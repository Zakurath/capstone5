      </div>
      <div class='l'>
      <label >(A3)</label>
      </div>
    </div>Moreover, the continuity of the second-order derivatives at an internal knot, i.e., <math display='inline'><semantics>
  <mrow>
    <msup>
      <mi>y</mi>
      <mrow>
        <mo>″</mo>
      </mrow>
    </msup>
    <mrow>
      <mo stretchy="false">(</mo>
      <msubsup>
        <mi>x</mi>
        <mi>i</mi>
        <mo>−</mo>
      </msubsup>
      <mo stretchy="false">)</mo>
    </mrow>
    <mo>=</mo>
    <msup>
      <mi>y</mi>
      <mrow>
        <mo>″</mo>
      </mrow>
    </msup>
    <mrow>
      <mo stretchy="false">(</mo>
      <msubsup>
        <mi>x</mi>
        <mi>i</mi>
        <mo>+</mo>
      </msubsup>
      <mo stretchy="false">)</mo>
    </mrow>
  </mrow>
</semantics></math>, yields
        <div class='html-disp-formula-info' id='FD31-jimaging-11-00014'>
      <div class='f'>
        <math display='block'><semantics>
  <mtable displaystyle="true">
    <mtr>
      <mtd columnalign="right">
        <mrow/>
      </mtd>
      <mtd/>
      <mtd columnalign="left">
        <mrow>
          <msub>
            <mi>λ</mi>
            <mi>i</mi>
          </msub>
          <msub>
            <mi>m</mi>
            <mrow>
              <mi>i</mi>
              <mo>−</mo>
              <mn>1</mn>
            </mrow>
          </msub>
          <mo>+</mo>
          <mn>2</mn>
          <msub>
            <mi>m</mi>
            <mi>i</mi>
          </msub>
          <mo>+</mo>
          <msub>
            <mi>μ</mi>
            <mi>i</mi>
          </msub>
          <msub>
            <mi>m</mi>
            <mrow>
              <mi>i</mi>
              <mo>+</mo>
              <mn>1</mn>
            </mrow>
          </msub>
          <mo>=</mo>
          <msub>
            <mi>c</mi>
            <mi>i</mi>
          </msub>
          <mo>,</mo>
          <mspace width="3.33333pt"/>
          <mspace width="3.33333pt"/>
          <mi>i</mi>
          <mo>=</mo>
          <mn>1</mn>
          <mo>,</mo>
          <mn>2</mn>
          <mo>,</mo>
          <mo>…</mo>
          <mo>,</mo>
          <mi>n</mi>
          <mo>−</mo>
          <mn>1</mn>
          <mo>,</mo>
        </mrow>
      </mtd>
    </mtr>
  </mtable>
</semantics></math>
      </div>
      <div class='l'>
      <label >(A4)</label>
      </div>
    </div>
        where
        <div class='html-disp-formula-info' id='FD32-jimaging-11-00014'>
      <div class='f'>
        <math display='block'><semantics>
  <mtable displaystyle="true">
    <mtr>
      <mtd columnalign="right">
        <mrow/>
      </mtd>
      <mtd/>
      <mtd columnalign="left">
        <mrow>
          <mspace width="-28.45274pt"/>
          <msub>
            <mi>λ</mi>
            <mi>i</mi>
          </msub>
          <mo>=</mo>
          <mstyle scriptlevel="0" displaystyle="true">
            <mfrac>
              <msub>
                <mi>h</mi>
                <mrow>
                  <mi>i</mi>
                  <mo>+</mo>
