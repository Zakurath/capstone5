      Click here to enlarge figure
    </a></p> -->

  </div>
</div>
<div class="html-fig_show  mfp-hide" id="fig_body_display_jimaging-11-00014-f009">
  <div class="html-caption"> <b>Figure 9.</b>
      Adding intermediate points.</div>
  <div class="html-img"><img data-large="/jimaging/jimaging-11-00014/article_deploy/html/images/jimaging-11-00014-g009.png" data-original="/jimaging/jimaging-11-00014/article_deploy/html/images/jimaging-11-00014-g009.png" alt="Jimaging 11 00014 g009" data-lsrc="/jimaging/jimaging-11-00014/article_deploy/html/images/jimaging-11-00014-g009.png" /></div>
</div>
<div class="html-fig-wrap"
  id="jimaging-11-00014-f010"
  
  data-position="anchor"
>
  <div class='html-fig_img'>
    <div class="html-figpopup html-figpopup-link" data-counterslinkmanual = "https://www.mdpi.com/2313-433X/11/1/14/display"
  href="#fig_body_display_jimaging-11-00014-f010">
      <img data-large="/jimaging/jimaging-11-00014/article_deploy/html/images/jimaging-11-00014-g010.png" data-original="/jimaging/jimaging-11-00014/article_deploy/html/images/jimaging-11-00014-g010.png" alt="Jimaging 11 00014 g010" data-lsrc="/jimaging/jimaging-11-00014/article_deploy/html/images/jimaging-11-00014-g010-550.jpg" />
