    </mtr>
  </mtable>
</semantics></math>
      </div>
      <div class='l'>
      <label >(25)</label>
      </div>
    </div>
        where <math display='inline'><semantics>
  <mrow>
    <mover accent="true">
      <mi>g</mi>
      <mo>˙</mo>
    </mover>
    <mo>=</mo>
    <msub>
      <mover accent="true">
        <mi>g</mi>
        <mo>˙</mo>
      </mover>
      <mrow>
        <mi>I</mi>
        <mi>J</mi>
        <mo>,</mo>
        <mi>k</mi>
        <mo>ℓ</mo>
      </mrow>
    </msub>
  </mrow>
</semantics></math> and <math display='inline'><semantics>
  <mrow>
    <msub>
      <mover accent="true">
        <mi>b</mi>
        <mo stretchy="false">^</mo>
      </mover>
      <mi>μ</mi>
    </msub>
    <mrow>
      <mo stretchy="false">(</mo>
      <mi>x</mi>
      <mo>,</mo>
      <mi>y</mi>
      <mo stretchy="false">)</mo>
    </mrow>
    <mo>=</mo>
    <msub>
      <mover accent="true">
        <mi>ϕ</mi>
        <mo stretchy="false">^</mo>
      </mover>
      <mi>μ</mi>
    </msub>
    <mrow>
      <mo stretchy="false">(</mo>
      <mover accent="true">
        <mi>ξ</mi>
        <mo stretchy="false">^</mo>
      </mover>
      <mrow>
        <mo stretchy="false">(</mo>
        <mi>x</mi>
        <mo>,</mo>
        <mi>y</mi>
        <mo stretchy="false">)</mo>
      </mrow>
      <mo>,</mo>
      <mover accent="true">
        <mi>η</mi>
        <mo stretchy="false">^</mo>
      </mover>
      <mrow>
        <mo stretchy="false">(</mo>
        <mi>x</mi>
        <mo>,</mo>
        <mi>y</mi>
        <mo stretchy="false">)</mo>
      </mrow>
      <mo stretchy="false">)</mo>
    </mrow>
  </mrow>
</semantics></math>. Note that no nonlinear solutions are needed in (<a href="#FD25-jimaging-11-00014" class="html-disp-formula">25</a>) either. Here, only one question remains: How do we find <math display='inline'><semantics>
  <mrow>
    <mo stretchy="false">(</mo>
    <msub>
      <mover accent="true">
        <mi>ξ</mi>
        <mo stretchy="false">^</mo>
      </mover>
      <mrow>
        <mi>I</mi>
        <mi>J</mi>
      </mrow>
    </msub>
    <mo>,</mo>
    <msub>
      <mover accent="true">
        <mi>η</mi>
        <mo stretchy="false">^</mo>
      </mover>
      <mrow>
        <mi>I</mi>
        <mi>J</mi>
      </mrow>
    </msub>
    <mo stretchy="false">)</mo>
  </mrow>
</semantics></math> from the FDM solutions <math display='inline'><semantics>
  <mrow>
    <mo stretchy="false">(</mo>
    <msub>
      <mover accent="true">
        <mi>x</mi>
        <mo stretchy="false">^</mo>
      </mover>
      <mrow>
        <mi>i</mi>
        <mi>j</mi>
      </mrow>
    </msub>
    <mo>,</mo>
    <msub>
      <mover accent="true">
        <mi>y</mi>
        <mo stretchy="false">^</mo>
      </mover>
      <mrow>
        <mi>i</mi>
        <mi>j</mi>
      </mrow>
    </msub>
    <mo stretchy="false">)</mo>
  </mrow>
</semantics></math>? Now, we propose a new technique consisting of four mini steps.</div><dl class='html-alpha-lower'><dt id=''>Step (a):</dt><dd><div class='html-p'>Compute all <math display='inline'><semantics>
  <msub>
    <mover accent="true">
      <mi>x</mi>
      <mo stretchy="false">^</mo>
    </mover>
    <mrow>
      <mi>i</mi>
      <mi>j</mi>
    </mrow>
  </msub>
</semantics></math> and <math display='inline'><semantics>
  <msub>
    <mover accent="true">
      <mi>y</mi>
      <mo stretchy="false">^</mo>
    </mover>
    <mrow>
      <mi>i</mi>
      <mi>j</mi>
    </mrow>
  </msub>
</semantics></math> by the FDM in Step II of <a href="#sec2dot1-jimaging-11-00014" class="html-sec">Section 2.1</a>,
            <div class='html-disp-formula-info' id=''>
      <div class='f'>
        <math display='block'><semantics>
  <mtable displaystyle="true">
    <mtr>
