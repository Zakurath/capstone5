          <mo>=</mo>
          <msub>
            <mi>b</mi>
            <mn>3</mn>
          </msub>
          <mo>,</mo>
        </mrow>
      </mtd>
    </mtr>
  </mtable>
</semantics></math>
      </div>
      <div class='l'>
      <label >(27)</label>
      </div>
    </div>
      where the coefficients <math display='inline'><semantics>
