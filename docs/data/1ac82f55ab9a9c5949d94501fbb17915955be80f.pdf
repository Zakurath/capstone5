                  <mi>i</mi>
                </msub>
                <mo>+</mo>
                <msub>
                  <mi>h</mi>
                  <mrow>
                    <mi>i</mi>
                    <mo>+</mo>
                    <mn>1</mn>
                  </mrow>
                </msub>
              </mrow>
            </mfrac>
          </mstyle>
          <mfenced separators="" open="(" close=")">
            <msub>
              <mi>h</mi>
              <mi>i</mi>
            </msub>
            <mstyle scriptlevel="0" displaystyle="true">
              <mfrac>
                <mrow>
                  <msub>
                    <mi>y</mi>
                    <mrow>
                      <mi>i</mi>
                      <mo>+</mo>
                      <mn>1</mn>
                    </mrow>
                  </msub>
                  <mo>−</mo>
                  <msub>
                    <mi>y</mi>
                    <mi>i</mi>
                  </msub>
                </mrow>
                <msub>
                  <mi>h</mi>
                  <mrow>
                    <mi>i</mi>
                    <mo>+</mo>
                    <mn>1</mn>
                  </mrow>
                </msub>
              </mfrac>
            </mstyle>
            <mo>+</mo>
            <msub>
              <mi>h</mi>
              <mrow>
                <mi>i</mi>
                <mo>+</mo>
                <mn>1</mn>
              </mrow>
            </msub>
            <mstyle scriptlevel="0" displaystyle="true">
              <mfrac>
                <mrow>
                  <msub>
                    <mi>y</mi>
                    <mi>i</mi>
                  </msub>
                  <mo>−</mo>
                  <msub>
                    <mi>y</mi>
                    <mrow>
                      <mi>i</mi>
                      <mo>−</mo>
                      <mn>1</mn>
                    </mrow>
                  </msub>
                </mrow>
                <msub>
                  <mi>h</mi>
                  <mi>i</mi>
                </msub>
              </mfrac>
            </mstyle>
          </mfenced>
          <mo>.</mo>
        </mrow>
      </mtd>
    </mtr>
  </mtable>
</semantics></math>
      </div>
      <div class='l'>
      <label >(A5)</label>
      </div>
    </div>Equations (<a href="#FD31-jimaging-11-00014" class="html-disp-formula">A4</a>) and (<a href="#FD32-jimaging-11-00014" class="html-disp-formula">A5</a>) are the exact cubic interpolation (<a href="#FD10-jimaging-11-00014" class="html-disp-formula">10</a>). This implies that by adding the continuity of second-order derivatives at the nodes, the ODE Hermite solutions lead to the cubic spline interpolant.</div><div class='html-p'>On the other hand, we may also explicitly derive the equations for the minimum energy <math display='inline'><semantics>
  <mrow>
    <msup>
      <mi>E</mi>
      <mo>*</mo>
    </msup>
    <mrow>
      <mo stretchy="false">(</mo>
      <mi>y</mi>
      <mrow>
        <mo stretchy="false">(</mo>
        <mi>S</mi>
        <mo stretchy="false">)</mo>
      </mrow>
      <mo stretchy="false">)</mo>
    </mrow>
  </mrow>
</semantics></math> in (<a href="#FD19-jimaging-11-00014" class="html-disp-formula">19</a>) to provide it exactly (<a href="#FD31-jimaging-11-00014" class="html-disp-formula">A4</a>). Since <math display='inline'><semantics>
  <mrow>
    <mi>p</mi>
    <mo stretchy="false">(</mo>
    <mi>S</mi>
    <mo stretchy="false">)</mo>
    <mo>≡</mo>
    <mn>1</mn>
  </mrow>
</semantics></math> and <math display='inline'><semantics>
  <mrow>
    <mi>f</mi>
    <mo>≡</mo>
    <mn>0</mn>
  </mrow>
</semantics></math>, we consider the energy <math display='inline'><semantics>
  <mrow>
    <mi>E</mi>
    <mrow>
      <mo stretchy="false">(</mo>
      <mi>y</mi>
      <mo stretchy="false">)</mo>
    </mrow>
    <mo>=</mo>
    <msubsup>
      <mo>∑</mo>
      <mrow>
        <mi>i</mi>
        <mo>=</mo>
        <mn>1</mn>
      </mrow>
      <mi>n</mi>
    </msubsup>
    <msub>
      <mi>E</mi>
      <mi>i</mi>
    </msub>
    <mrow>
      <mo stretchy="false">(</mo>
      <mi>y</mi>
      <mo stretchy="false">)</mo>
    </mrow>
  </mrow>
</semantics></math>, where
        <div class='html-disp-formula-info' id=''>
      <div class='f'>
        <math display='block'><semantics>
  <mtable displaystyle="true">
