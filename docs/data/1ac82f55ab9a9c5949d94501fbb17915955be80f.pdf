                  <mo>˙</mo>
                </mover>
              </msub>
              <mo>,</mo>
              <msub>
                <mi>y</mi>
                <mover accent="true">
                  <mi>g</mi>
                  <mo>˙</mo>
                </mover>
              </msub>
              <mo stretchy="false">)</mo>
            </mrow>
            <mo stretchy="false">)</mo>
          </mrow>
          <mo>=</mo>
          <mstyle scriptlevel="0" displaystyle="true">
            <mfrac>
              <msup>
                <mi>h</mi>
                <mn>2</mn>
              </msup>
              <msup>
                <mi>H</mi>
                <mn>2</mn>
              </msup>
            </mfrac>
          </mstyle>
          <munder>
            <mo>∑</mo>
            <mrow>
              <mi>k</mi>
              <mo>,</mo>
              <mo>ℓ</mo>
            </mrow>
          </munder>
          <msub>
            <mover accent="true">
              <mi>b</mi>
              <mo stretchy="false">^</mo>
            </mover>
