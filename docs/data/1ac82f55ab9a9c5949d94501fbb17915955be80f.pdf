          </msub>
          <mrow>
            <mo stretchy="false">(</mo>
            <msub>
              <mi>x</mi>
              <mover accent="true">
                <mi>g</mi>
                <mo>˙</mo>
              </mover>
            </msub>
            <mo>,</mo>
            <msub>
              <mi>y</mi>
