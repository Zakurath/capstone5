            <mo>+</mo>
            <mn>2</mn>
            <msub>
              <mi>m</mi>
              <mi>i</mi>
            </msub>
            <mo>]</mo>
          </mrow>
          <mo>−</mo>
          <mstyle scriptlevel="0" displaystyle="true">
            <mfrac>
              <mn>6</mn>
