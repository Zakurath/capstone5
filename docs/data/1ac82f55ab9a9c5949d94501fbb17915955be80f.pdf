            </msubsup>
            <msub>
              <mi>ψ</mi>
              <mn>0</mn>
            </msub>
            <mrow>
              <mo stretchy="false">(</mo>
              <mstyle scriptlevel="0" displaystyle="true">
                <mfrac>
                  <mrow>
                    <mi>S</mi>
                    <mo>−</mo>
                    <msub>
                      <mi>S</mi>
