                        <mo>,</mo>
                        <mi>j</mi>
                      </mrow>
                    </msub>
                    <mrow>
                      <mo>(</mo>
                      <mi>X</mi>
                      <mo>)</mo>
                    </mrow>
                    <mo> </mo>
                  </mrow>
                  <mo>&gt;</mo>
                </mrow>
                <mo> </mo>
                <mn>0</mn>
              </mrow>
            </mtd>
          </mtr>
          <mtr>
            <mtd>
              <mrow>
                <msub>
                  <mi>J</mi>
