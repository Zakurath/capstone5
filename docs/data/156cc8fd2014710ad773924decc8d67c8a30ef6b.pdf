                      <mo>)</mo>
                    </mrow>
                    <mo> </mo>
                  </mrow>
                  <mo>&gt;</mo>
                </mrow>
                <mo> </mo>
                <mn>0</mn>
              </mrow>
            </mtd>
          </mtr>
          <mtr>
            <mtd>
              <mrow>
                <msub>
                  <mi>J</mi>
                  <mrow>
                    <mi>i</mi>
                    <mo>,</mo>
                    <mi>t</mi>
                    <mo>=</mo>
                    <mi>N</mi>
                    <mi>o</mi>
                    <mi>n</mi>
                    <mi>S</mi>
                    <mi>t</mi>
                    <mi>e</mi>
                    <mi>g</mi>
                    <mi>o</mi>
                  </mrow>
                </msub>
                <mrow>
                  <mo>(</mo>
                  <mi>X</mi>
                  <mo>)</mo>
                </mrow>
                <mrow>
                  <mo>|</mo>
                  <mrow>
                    <msub>
                      <mi>J</mi>
                      <mrow>
                        <mi>i</mi>
                        <mo>,</mo>
                        <mi>t</mi>
                        <mo>=</mo>
                        <mi>s</mi>
                        <mi>t</mi>
                        <mi>e</mi>
                        <mi>g</mi>
                        <mi>o</mi>
                      </mrow>
                    </msub>
                    <mrow>
                      <mo>(</mo>
