                <mrow>
                  <mo>&lt;</mo>
                  <mrow>
                    <mo> </mo>
                    <mn>0</mn>
                    <mo> </mo>
                    <mi>o</mi>
                    <mi>r</mi>
                    <mo> </mo>
                    <msub>
                      <mi>J</mi>
                      <mrow>
                        <mi>i</mi>
                        <mo>,</mo>
                        <mi>t</mi>
                        <mo>=</mo>
                        <mi>s</mi>
                        <mi>t</mi>
                        <mi>e</mi>
                        <mi>g</mi>
                        <mi>o</mi>
                      </mrow>
                    </msub>
                    <mrow>
                      <mo>(</mo>
