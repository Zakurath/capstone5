								alt=""
							>
						</a>
									</div>
			
										<div class="download">
																		
	
							

<a class="galley-link btn btn-primary pdf" role="button" href="https://www.journalofbabylon.com/index.php/JUBPAS/article/view/5650/4243">

		
	PDF

	</a>
																				</div>
			
			<div class="list-group">

													<div class="list-group-item date-published">
												<strong>Published:</strong>
						10-05-2025
					</div>
																								
																						<div class="list-group-item doi">
												<strong>DOI:</strong>
						<a href="https://doi.org/10.29196/jubpas.v33i1.5650">
							https://doi.org/10.29196/jubpas.v33i1.5650
						</a>
					</div>
				
													<div class="list-group-item keywords">
						<strong>						Keywords:</strong>
						<div class="">
							<span class="value">
																	cyber security threats, 																	financial stability, 																	data breaches, 																	brand reputation, 																	mitigation strategies, 																	multi-factor authentication(MFA), 																	machine learning in cyber security															</span>
						</div>
