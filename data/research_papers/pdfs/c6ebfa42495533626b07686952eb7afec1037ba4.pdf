            <h1 class="title hypothesis_container" itemprop="name">
                Simulated Adversarial Attacks on Traffic Sign Recognition of Autonomous Vehicles<sup>&nbsp;†</sup>             </h1>

            <div class="art-authors hypothesis_container">
