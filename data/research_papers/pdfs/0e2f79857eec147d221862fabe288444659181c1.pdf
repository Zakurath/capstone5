    <meta name="journal_id" content="10462"/>
    <meta name="dc.title" content="Staying ahead of phishers: a review of recent advances and emerging methodologies in phishing detection"/>
    <meta name="dc.source" content="Artificial Intelligence Review 2024 58:2"/>
    <meta name="dc.format" content="text/html"/>
    <meta name="dc.publisher" content="Springer"/>
