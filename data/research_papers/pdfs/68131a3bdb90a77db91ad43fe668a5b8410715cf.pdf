	<!-- <div id="authorString"><em>Hartono Hartono, Ryan Aji Wijaya, Khusnul Khotimah</em></div> -->
							
				
	 	<sup>(1)  *</sup> Hartono Hartono <a href="mailto:hartono@umko.ac.id" class="icon"><img src="https://ijair.id/lib/pkp/templates/images/icons/mail.gif" width="16" height="14" alt="Mail" /></a><em> <font size="0.4pt" color="#2e2727">(Universitas Muhammadiyah Kotabumi, Indonesia)</font></em><br />
						
				
