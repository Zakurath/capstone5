	<h3>
	Development of Detection and Mitigation of Advanced Persistent Threats Using Artificial Intelligence and Multi-Layer Security on Cloud Computing Infrastructure</h3>	</div>
	    </td><td>
	
<!-- End plumX --> 
<script type="text/javascript" src="//d39af2mgp1pqhg.cloudfront.net/widget-popup.js"></script>
<!-- End plumX -->
