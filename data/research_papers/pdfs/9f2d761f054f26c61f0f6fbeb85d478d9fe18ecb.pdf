    "       preferredFont: null,\n" +
    "       preferredFonts: null,\n" +
    "       webFont:\"Gyre-Pagella\",\n" +
    "       imageFont:'TeX',\n" +
    "       undefinedFamily:\"'Arial Unicode MS',serif\",\n" +
    "       linebreaks: { automatic: false }\n" +
    "   },\n" +
    "   \"TeX\": {\n" +
    "       extensions: ['noErrors.js'],\n" +
    "       noErrors: {\n" +
    "           inlineDelimiters: [\"\",\"\"],\n" +
    "           multiLine: true,\n" +
    "           style: {\n" +
    "               'font-size':   '90%',\n" +
    "               'text-align':  'left',\n" +
