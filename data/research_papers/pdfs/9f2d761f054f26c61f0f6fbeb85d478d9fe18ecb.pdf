                        <span itemprop="publisher" content="Multidisciplinary Digital Publishing Institute"></span><span itemprop="url" content="https://www.mdpi.com/1424-8220/24/15/4859"></span>

            <div class="article-icons"><span class="label openaccess" data-dropdown="drop-article-label-openaccess" aria-expanded="false">Open Access</span><span class="label articletype">Article</span></div>

            <h1 class="title hypothesis_container" itemprop="name">
                Adoption of Deep-Learning Models for Managing Threat in API Calls with Transparency Obligation Practice for Overall Resilience            </h1>

            <div class="art-authors hypothesis_container">
                                by
                    <span class="inlineblock "><div class='profile-card-drop' data-dropdown='profile-card-drop12951535' data-options='is_hover:true, hover_timeout:5000'>
