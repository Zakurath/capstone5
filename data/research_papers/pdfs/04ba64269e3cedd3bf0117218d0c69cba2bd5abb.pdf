function Toggle() { 
	var temp = document.getElementById("password"); 
	if (temp.type === "password") { 
		temp.type = "text"; 
		$('#show').attr("title","Hide Password");
	} 
	else { 
		temp.type = "password"; 
		$('#show').attr("title","Show Password");
	} 
} 
  </script> 
