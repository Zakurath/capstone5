1" colspan="1" valign="top" align="left" style="border-style: solid none solid; border-width: 0.0 0 0.0; font-weight: normal; background-color: white; width: 8.371683148927838%; vertical-align: top"><p>SOC</p></td>              <td rowspan="1" colspan="1" valign="top" align="left" style="border-style: solid none solid; border-width: 0.0 0 0.0; font-weight: normal; background-color: white; width: 91.62831685107217%; vertical-align: top"><p>Security Operations Center</p></td>            </tr>            <tr>              <td rowspan="1" colspan="1" valign="top" align="left" style="border-style: solid none solid; border-width: 0.0 0 0.0; font-weight: normal; background-color: white; width: 8.371683148927838%; vertical-align: top"><p>DDoS</p></td>              <td rowspan="1" colspan="1" valign="top" align="left" style="border-style: solid none solid; border-width: 0.0 0 0.0; font-weight: normal; background-color: white; width: 91.62831685107217%; vertical-align: top"><p>Distributed Denial of Service</p></td>            </tr>            <tr>              <td rowspan="1" colspan="1" valign="top" align="left" style="border-style: solid none solid; border-width: 0.0 0 0.0; font-weight: normal; background-color: white; width: 8.371683148927838%; vertical-align: top"><p>DoS</p></td>              <td rowspan="1" colspan="1" valign="top" align="left" style="border-style: solid none solid; border-width: 0.0 0 0.0; font-weight: normal; background-color: white; width: 91.62831685107217%; vertical-align: top"><p>Denial of Service</p></td>            </tr>            <tr>              <td rowspan="1" colspan="1" valign="top" align="left" style="border-style: solid none solid; border-width: 0.0 0 0.0; font-weight: normal; background-color: white; width: 8.371683148927838%; vertical-align: top"><p>HCI</p></td>              <td rowspan="1" colspan="1" valign="top" align="left" style="border-style: solid none solid; border-width: 0.0 0 0.0; font-weight: normal; background-color: white;