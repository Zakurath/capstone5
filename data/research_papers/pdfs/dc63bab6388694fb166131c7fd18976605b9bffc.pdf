        transition: max-height 0.4s ease;
    }
    .collapsible-section.collapsed {
        max-height: 500px;
    }
    .collapsible-section.collapsed::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 100px;
        background: linear-gradient(to bottom, rgba(255,255,255,0), rgba(255,255,255,1));
