<script>
function switchCitationFormat(format) {
    // Remove active class from all tabs and contents
    document.querySelectorAll('.citation-tab').forEach(tab => tab.classList.remove('active'));
    document.querySelectorAll('.citation-content').forEach(content => content.classList.remove('active'));
    
    // Add active class to selected tab and content
    event.target.classList.add('active');
    document.getElementById(format + '-citation').classList.add('active');
}

function copyCitation(format) {
    const citationElement = document.getElementById(format + '-citation').querySelector('.citation-text');
    const text = citationElement.innerText || citationElement.textContent;
    
    // Create temporary textarea to copy text
    const textarea = document.createElement('textarea');
    textarea.value = text;
    textarea.style.position = 'fixed';
    textarea.style.opacity = '0';
    document.body.appendChild(textarea);
    textarea.select();
    
    try {
        document.execCommand('copy');
        
        // Show success feedback
        const link = event.target.closest('.copy-link');
        const originalHTML = link.innerHTML;
        link.classList.add('copied');
        link.innerHTML = '<i class="fa fa-check"></i> Copied!';
        
        setTimeout(() => {
            link.classList.remove('copied');
            link.innerHTML = originalHTML;
        }, 2000);
    } catch (err) {
        console.error('Failed to copy citation:', err);
    }
    
    document.body.removeChild(textarea);
}

function toggleSection(sectionName) {
    const section = document.getElementById(sectionName + '-section');
    const btn = document.getElementById(sectionName + '-expand-btn');
    
    if (section.classList.contains('collapsed')) {
        section.classList.remove('collapsed');
        section.style.maxHeight = section.scrollHeight + 'px';
        btn.innerHTML = '<i class="fa fa-angle-up"></i> Show Less';
    } else {
        section.classList.add('collapsed');
        section.style.maxHeight = '500px';
        btn.innerHTML = '<i class="fa fa-angle-down"></i> Show More';
        // Scroll to section header smoothly
        document.getElementById(sectionName).scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
}

// Check if sections need expand button on load
window.addEventListener('DOMContentLoaded', function() {
    ['abstract', 'references'].forEach(function(sectionName) {
        const section = document.getElementById(sectionName + '-section');
        const btn = document.getElementById(sectionName + '-expand-btn');
        
        if (section && btn) {
            // If content height is less than or equal to collapsed height, hide the button
            if (section.scrollHeight <= 500) {
                btn.classList.add('hidden');
                section.classList.remove('collapsed');
            }
        }
    });
});
</script>



