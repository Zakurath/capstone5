        <article ><div class='html-article-content'>

                        <span itemprop="publisher" content="Multidisciplinary Digital Publishing Institute"></span><span itemprop="url" content="https://www.mdpi.com/2076-3417/14/23/10808"></span>

            <div class="article-icons"><span class="label openaccess" data-dropdown="drop-article-label-openaccess" aria-expanded="false">Open Access</span><span class="label articletype">Article</span></div>

            <h1 class="title hypothesis_container" itemprop="name">
                Privacy-Preserving Data Sharing in Telehealth Services            </h1>

            <div class="art-authors hypothesis_container">
                                by
                    <span class="inlineblock "><div class='profile-card-drop' data-dropdown='profile-card-drop13431000' data-options='is_hover:true, hover_timeout:5000'>
