                    <h1 class="c-article-title" data-test="article-title" data-article-title="">A framework reforming personalized Internet of Things by federated meta-learning</h1>
                    <ul class="c-article-author-list c-article-author-list--short" data-test="authors-list" data-component-authors-activator="authors-list"><li class="c-article-author-list__item"><a data-test="author-name" data-track="click" data-track-action="open author" data-track-label="link" data-track-index="1_6" data-track-context="researcher popup with no profile" href="#auth-Linlin-You-Aff1" data-author-popup="auth-Linlin-You-Aff1" data-author-search="You, Linlin">Linlin You</a><span class="u-js-hide"> 
            <a class="js-orcid" href="https://orcid.org/0000-0001-6287-8095"><span class="u-visually-hidden">ORCID: </span>orcid.org/0000-0001-6287-8095</a></span><sup class="u-js-hide"><a href="#Aff1">1</a></sup>, </li><li class="c-article-author-list__item"><a data-test="author-name" data-track="click" data-track-action="open author" data-track-label="link" data-track-index="2_6" data-track-context="researcher popup with no profile" href="#auth-Zihan-Guo-Aff1" data-author-popup="auth-Zihan-Guo-Aff1" data-author-search="Guo, Zihan">Zihan Guo</a><span class="u-js-hide"> 
            <a class="js-orcid" href="https://orcid.org/0000-0002-2401-9174"><span class="u-visually-hidden">ORCID: </span>orcid.org/0000-0002-2401-9174</a></span><sup class="u-js-hide"><a href="#Aff1">1</a></sup>, </li><li class="c-article-author-list__item c-article-author-list__item--hide-small-screen"><a data-test="author-name" data-track="click" data-track-action="open author" data-track-label="link" data-track-index="3_6" data-track-context="researcher popup with no profile" href="#auth-Chau-Yuen-Aff2" data-author-popup="auth-Chau-Yuen-Aff2" data-author-search="Yuen, Chau" data-corresp-id="c1">Chau Yuen<svg width="16" height="16" focusable="false" role="img" aria-hidden="true" class="u-icon"><use xmlns:xlink="http://www.w3.org/1999/xlink" xlink:href="#icon-eds-i-mail-medium"></use></svg></a><span class="u-js-hide"> 
