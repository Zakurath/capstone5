<math xmlns="http://www.w3.org/1998/Math/MathML" id="mml-ieqn-35"><mrow><msub><mi>D</mi><mrow><mi>b</mi><mi>a</mi><mi>l</mi><mi>a</mi><mi>n</mi><mi>c</mi><mi>e</mi><mi>d</mi></mrow></msub></mrow><mo stretchy="false">←</mo><mi mathvariant="normal">∅</mi></math></span>
