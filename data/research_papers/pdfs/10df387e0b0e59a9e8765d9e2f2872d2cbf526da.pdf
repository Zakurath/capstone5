<th>ITERATE</th>
<th>RDWTI</th>
<th>TWEED</th>
</tr>
</thead>
<tbody>
<tr>
<td>Scope</td>
<td>International + domestic (U.S.A)</td>
<td>International</td>
<td>International + domestic (U.S.A)</td>
<td>Western Europe</td>
</tr>
<tr>
