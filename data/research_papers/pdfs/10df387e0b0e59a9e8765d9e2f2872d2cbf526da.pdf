                        reject(new Error('Failed to load fbevents.js'));
                    });
                    s = b.getElementsByTagName(e)[0];
                    s.parentNode.insertBefore(t, s);
                })(window, document, 'script', 'https://connect.facebook.net/en_US/fbevents.js');
            });

            return window._fbqManager.loadingPromise;
        }

        // Initialize pixel (only once per ID)
        async function initPixelOnce(pixelId) {
            if (!pixelId) return;
            pixelId = String(pixelId);

            if (window._fbqManager.initializedIds.has(pixelId)) return; // already initialized

            try {
                await injectFbeventsIfNeeded();

                if (window.fbq && window.fbq.callMethod) {
                    // fbq is ready
                    try {
                        fbq('init', pixelId);
                        fbq('track', 'PageView');
                        window._fbqManager.initializedIds.add(pixelId);
                    } catch (e) {
                        console.warn('fbq init/track error', e);
                    }
                } else {
                    // fallback: push to queue on shim
                    window.fbq = window.fbq || function () {
                        window.fbq.callMethod ? window.fbq.callMethod.apply(window.fbq, arguments) : window.fbq.queue.push(arguments);
                    };
                    window.fbq.queue = window.fbq.queue || [];
                    window.fbq('init', pixelId);
                    window.fbq('track', 'PageView');
                    window._fbqManager.initializedIds.add(pixelId);
                }
            } catch (err) {
                console.warn('Failed to load Meta Pixel script:', err);
            }
        }

        // Stop sending events from this manager (we do NOT remove the script)
        function deactivatePixelManager(pixelId) {
            // Remove the id from our initialized list so future calls won't re-init automatically
            if (pixelId) window._fbqManager.initializedIds.delete(String(pixelId));
            // Mark consent false — our wrapper will refuse to send further events.
            window._fbqManager.consentGranted = false;
            location.reload(); // force full page reload to guarantee pixel is deleted
        }

        function consentToMetaPixel({consent, enableRevoke = false}) {
            if (consent && !window._fbqManager.consentGranted) {
                // newly granted
                window._fbqManager.consentGranted = true;

                initPixelOnce(PIXEL_ID);
            } else if (enableRevoke && !consent && window._fbqManager.consentGranted) {
                // revoked
                deactivatePixelManager(PIXEL_ID);
            }
        }

        return {
            seekConsent: consentToMetaPixel,
            initPixelOnce: initPixelOnce,
            deactivatePixelManager: deactivatePixelManager
        }
    })()
</script>


<script type="text/javascript">
    (function () {
        // Main integration with airgap
        window.airgap = window.airgap || {
            ready: function () {
            }
        };

        PeerJ.Com.CookieConsent.init()

        // ↓↓↓↓ PUT YOUR COOKIE ETC. CONSENT IN HERE ↓↓↓↓
        function checkConsent(
                consent = {Advertising: false, Analytics: false, Functional: false},
                enableRevoke = false) {

            /**
             * 1. ensure your service is imported above
             * 2. ensure it provides a `seekConsent` method (see existing services for examples)
             * 3. supply the service name and its consent values in the object below.
             */
            var services = {
                'metaPixel': consent.Advertising && consent.Analytics,
                'GA': consent.Analytics,
                'GoogleTagManager': consent.Analytics,
            }

            var keys = Object.keys(services);
            for (var i = 0; i < keys.length; i++) {
                var key = keys[i];
                var value = services[key];

                try {
                    if (PeerJ.Com.hasOwnProperty(key)) {
                        PeerJ.Com[key].seekConsent({
                            consent: value,
                            enableRevoke: enableRevoke
                        });
                    }
                } catch (e) {
                    console.warn(e);
                }
            }

            if (!consent.Analytics && !consent.Advertising && !consent.Functional) {
                PeerJ.Com.CookieConsent.deleteNonEssentialCookies()
            }
        }

        window.airgap.ready(async function (airgap) {
            try {
                await airgap.sync();
                var consent = await airgap.getConsent();

                checkConsent(consent && consent.purposes)

                try {
                    airgap.addEventListener('consent-change', async function (d) {
                        if (!d || !d.detail || !d.detail.changes) return;

                        // Note: many CMPs send only changed purposes — for robustness, fetch consent again
                        var consent = await airgap.getConsent();

                        checkConsent(consent && consent.purposes, true)

                        // ↓↓↓ MUST GO LAST DO NOT CHECK ANYTHING BELOW THIS SCOPE ↓↓↓
                        if (window._fbqManager) {
                            if (!window._fbqManager.consentGranted) {
                                location.reload()
                            }
                        }
                    });
                } catch (e) {
                    console.warn('airgap addEventListener failed', e);
                }
            } catch (err) {
                console.warn('airgap integration failed', err);
            }
        });
    })();
</script>
    
<script>
    var campaign_keywords = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term'];
    var kw = '';
    var lastUtms = {};
    var firstUtms = {};
    var allUtms = {};

    function campaignParams() {
        var index;
        for (index = 0; index < campaign_keywords.length; ++index) {
            kw = getQueryParam(document.URL, campaign_keywords[index]);
            if (kw.length) {
                lastUtms[campaign_keywords[index] + '-last'] = kw;
                firstUtms[campaign_keywords[index] + '-first'] = kw;
                allUtms[campaign_keywords[index] + '-all'] = kw;
            }
        }
    }

    function updatePreregCookie(preregCookie, firstUtmKey) {
        var utmVal = firstUtms[firstUtmKey];
        if (utmVal) {
            var existingPreregCampaign = $.cookie(preregCookie);
            var appendPreregCampaign;
            if (!existingPreregCampaign) {
                appendPreregCampaign = utmVal;
            } else {
                appendPreregCampaign = existingPreregCampaign + ',' + utmVal;

            }
            $.cookie(preregCookie, appendPreregCampaign, {expires: 365, path: "/"});
        }
    }

    function getQueryParam(url, param) {
        // Expects a raw URL
        param = param.replace(/[[]/, "\[").replace(/[]]/, "\]");
        var regexS = "[\?&]" + param + "=([^&#]*)",
                regex = new RegExp( regexS ),
                results = regex.exec(url);
        if (results === null || (results && typeof(results[1]) !== 'string' && results[1].length)) {
            return '';
        } else {
            return decodeURIComponent(results[1]).replace(/\W/gi, ' ');
        }
    }

    function articlePageEvent() {
        var articleContainer = $('.publication-jsondata');
        if (articleContainer.length) {
            var data = articleContainer.data('publication-meta');

            // Must be public
            if (data.publicationSubjects.length) {

                var eventName = 'Viewed-article';
                var preprint = data.preprint;
                if (preprint) {
                    eventName = 'Viewed-preprint';
                }

                data['ip-hash'] = 'd2f94db20b4bec67bbb1804dc8e64e9e';
                mixpanel.track(eventName, data);
            }
        }
    }

    function sectionListViewEvent() {
            }
</script>










