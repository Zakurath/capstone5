    <div class="u-js-hide" data-component="article-subject-links">
        <h3 class="c-article__sub-heading">Subjects</h3>
        <ul class="c-article-subject-list">
            <li class="c-article-subject-list__subject"><a href="/subjects/computer-science" data-track="click" data-track-action="view subject" data-track-label="link">Computer science</a></li><li class="c-article-subject-list__subject"><a href="/subjects/information-technology" data-track="click" data-track-action="view subject" data-track-label="link">Information technology</a></li>
