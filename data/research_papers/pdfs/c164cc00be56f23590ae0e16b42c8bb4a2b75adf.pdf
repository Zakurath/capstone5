                <div class="fe-paper-detail__item">
                    <h4 class="fe-paper-name">
                        An Efficient IoT Based Intrusion Detection System Using Optimization Kernel Extreme Learning Machine
                    </h4>
                    <p>
                                                <a
                            href="javascript:void(0);"
                            id="paperPdf"
                            data-href="../../ijcnis/ijcnis-v17-n2/IJCNIS-V17-N2-5.pdf"
