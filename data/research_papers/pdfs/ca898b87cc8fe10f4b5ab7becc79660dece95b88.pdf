	<h2 class="title">JOURNAL ARCHIVE</h2>
	<div class="content">
		<div class="row">
<div class="col-md-12" style="text-align: center;">
<div id="accordion" class="panel-group" role="tablist" aria-multiselectable="true">
<div class="panel panel-default">
<div id="heading11" class="panel-heading" role="tab">
<h4 class="panel-title"><a role="button" href="#collapse11" data-toggle="collapse" data-parent="#accordion" aria-expanded="true" aria-controls="collapse11"> Volume 11 (2026) </a></h4>
</div>
<div id="collapse11" class="panel-collapse collapse" role="tabpanel" aria-labelledby="heading11">
<div class="panel-body">
