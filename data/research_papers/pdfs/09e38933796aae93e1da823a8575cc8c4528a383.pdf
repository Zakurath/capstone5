  <script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script>
    function scrollToAnchor(selector) {
      const destination = $("#" + selector);
      $('html,body').animate({
        scrollTop: destination.offset().top - 100
      }, 'slow');
    }

    function moveScroller() {
      var $anchor = $("#sidediv");
      var $scroller = $('.fixed-sidebar');

      var move = function() {
        var st = $(window).scrollTop();
        var ot = $anchor.offset().top;
        if (st > ot) {
          $scroller.css({
            position: "fixed",
            top: "120px",
            // width: "263",
          });
        } else {
          $scroller.css({
            position: "relative",
            top: "",
            width: "263"
          });
        }
      };
      $(window).scroll(move);
      move();
    }
    $(function() {
      moveScroller();
    });
  </script>
  <script>
    $(document).ready(function() {
      getcomment('ART-1345');
    })

    function getcomment(id) {
      $.ajax({
        type: 'POST',
        url: 'get_comment.php',
        data: {
          id: id
        },
        cache: false,
        success: function(data) {
          //alert();
          $('#commentdiv').html(data);

        }
      })
    }

    function getcites(type, id) {
      $('#loading').show();
      $.ajax({
        type: 'POST',
        url: 'get_cites.php',
        data: {
          id: id,
          type: type
        },
        cache: false,
        success: function(data) {
          //alert();
          $('#citedatadiv').html(data);
          $('#loading').hide();
        }
      })
    }

    function citeitem(id) {
      $('#loading').show();
      $('#myModal3').modal('hide');
      $.ajax({
        type: 'POST',
        url: 'cite_popup.php',
        data: {
          id: id
        },
        cache: false,
        success: function(data) {
          //alert();
          $('#citeresult').html(data);
          $('#myModal3').modal('show');
          $('#loading').hide();
        }
      })
    }

    function showcothdetails(id) {
      var str = $('#cauthor' + id).val();
      $('#cauthor').html(str);
      $('#cauthor').toggle();
    }
    $('#refdiv').find(ul).css("list-style-type:none;");

    function comment(id) {
      $('#loading').show();
      $('#myModal2').modal('hide');
      $.ajax({
        type: 'POST',
        url: 'comment_popup.php',
        data: {
          id: id
        },
        cache: false,
        success: function(data) {
          //alert();
          $('#commentresult').html(data);
          $('#myModal2').modal('show');
          $('#loading').hide();
        }
      })
    }

    function addcoment(id) {
      var str = check();
      if (str == 1) {
        $('#loading').show();
        var s1, s2, s3, s4, s5;
        s1 = $('#prsnname').val();
        s2 = $("#city").val();
        s3 = $("#msgbody").val();

        var formData = new FormData();
        formData.append('id', id);
        formData.append('name', s1);
        formData.append('city', s2);
        formData.append('message', s3);
        $.ajax({
          type: 'POST',
          url: 'comment_add_qy.php',
          data: formData,
          cache: false,
          contentType: false,
          processData: false,

          success: function(data) {
            //alert(data);
            if (data == 1) {
              $('#myModal2').modal('hide');
              getcomment(id);
              alert("Comment Post Successfully..!!");
            } else if (data == 0)
              alert("Mandatory Field Required..!!");
            else
              alert("Mail not send due to some error..!!");
            $('#loading').hide();
          }
        });

      }
    }

    function check() {
      var s1, s2, s3;
      s1 = $('#name').val();
      s2 = $("#city").val();
      s3 = $("#msgbody").val();
      if (s1 == '') {
        alert("Name Required..!!");
        a = 0;
      } else if (s2 == '') {
        alert("City Required..!!");
        a = 0;
      } else if (s3 == '') {
        alert("Comment Required..!!");
        a = 0;
      } else
        a = 1;
      return a;
    }

    function emailarticle(id) {
      $('#loading').show();
      $('#myModal1').modal('hide');
      $.ajax({
        type: 'POST',
        url: 'email_popup.php',
        data: {
          id: id
        },
        cache: false,
        success: function(data) {
          //alert();
          $('#emailresult').html(data);
          $('#myModal1').modal('show');
          $('#loading').hide();

          $('#file').change(function() {
            var ext1 = this.value.match(/\.(.+)$/)[1];
            ext = ext1.toLowerCase();
            var size1 = this.files[0].size;

            if (ext == "pdf") {} else {
              alert("Select only pdf file..!!");
              this.value = '';
              return false;
            }


          });

        }
      })
    }

    function sendmail() {

      var str = check1();
      if (str == 1) {
        $('#loading').show();
        var s1, s2, s3, s4, s5;
        s1 = $('#toemail').val();
        s2 = $("#subject").val();
        s3 = $("#msgbody").val();
        s4 = $("#ccemail").val();
        s5 = $("#bccemail").val();

        var formData = new FormData();
        formData.append('toemail', s1);
        formData.append('subject', s2);
        formData.append('message', s3);
        formData.append('cc', s4);
        formData.append('bcc', s5);
        //formData.append('file', $('#file')[0].files[0]);

        $.ajax({
          type: 'POST',
          url: 'send_article_mail.php',
          data: formData,
          cache: false,
          contentType: false,
          processData: false,

          success: function(data) {
            //alert(data);
            if (data == 1) {
              $('#myModal1').modal('hide');
              alert("Mail Send Successfully..!!");
            } else if (data == 0)
              alert("mandatory Field Required..!!");
            else
              alert("Mail not send due to some error..!!");
            $('#loading').hide();
          }
        });

      }
    }

    function check1() {
      var s1, s2, s3;
      s1 = $('#toemail').val();
      s2 = $("#subject").val();
      s3 = $("#msgbody").val();
      if (s1 == '') {
        alert("To Required..!!");
        a = 0;
      } else if (s2 == '') {
        alert("Subject Required..!!");
        a = 0;
      } else if (s3 == '') {
        alert("Message Body Required..!!");
        a = 0;
      } else
        a = 1;
      return a;
    }

    function metadata(id) {
      $('#loading').show();
      $('#myModal').modal('hide');
      $.ajax({
        type: 'POST',
        url: 'get_metadata.php',
        data: {
          id: id
        },
        cache: false,
        success: function(data) {
          //alert();
          $('#metadataresult').html(data);
          $('#myModal').modal('show');
          $('#loading').hide();
        }
      })
    }

    function downloadadd(id) {
      $.ajax({
        type: 'POST',
        url: 'add_download.php',
        data: {
          'id': id
        },
        cache: false,
        success: function(data) {
          var str = $('#ttdownload' + id).html();
          str = Number(str) + 1;
          $('#ttdownload' + id).html(str);
        }
      });
    }
  </script>
